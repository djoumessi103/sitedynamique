<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CV — Djoumessi Magne Horlane-Jesica</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>

/* ════════════════════════════════════════════
   RESET
════════════════════════════════════════════ */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

:root {
  --navy : #0b1f3a;
  --cyan : #0ea5e9;
  --teal : #0d9488;
  --cyan2: #38bdf8;
  --muted: #64748b;
  --text : #1e293b;
  --bdr  : #e2e8f0;
  --sw   : 193px;   /* largeur sidebar */
}

/* ════════════════════════════════════════════
   BARRE D'ACTIONS  (jamais imprimée)
════════════════════════════════════════════ */
.print-bar {
  background: var(--navy); color:#fff;
  display:flex; align-items:center; justify-content:space-between;
  padding:9px 22px; gap:12px;
  position:sticky; top:0; z-index:100;
  font-family:'JetBrains Mono',monospace;
}
.print-bar p { font-size:.7rem; opacity:.65; }
.print-bar-btns { display:flex; gap:8px; }
.btn-print {
  background:var(--cyan); color:var(--navy);
  font-size:.75rem; font-weight:700;
  padding:6px 16px; border-radius:5px; border:none; cursor:pointer;
  display:inline-flex; align-items:center; gap:5px;
}
.btn-back {
  background:transparent; color:#fff;
  font-size:.75rem; font-weight:500;
  padding:6px 14px; border-radius:5px;
  border:1px solid rgba(255,255,255,.25);
  cursor:pointer; text-decoration:none;
  display:inline-flex; align-items:center; gap:5px;
}

/* ════════════════════════════════════════════
   WRAPPER ÉCRAN  →  centre la page A4
════════════════════════════════════════════ */
body {
  font-family:'Inter',sans-serif;
  background:#e8edf3;
  -webkit-print-color-adjust:exact;
  print-color-adjust:exact;
}

/* ════════════════════════════════════════════
   PAGE A4  —  dimensions FIXES en pixels
   794 × 1123 px  =  210 mm × 297 mm @96dpi
════════════════════════════════════════════ */
.page {
  width : 794px;
  height: 1123px;
  margin: 28px auto;
  background:#fff;
  box-shadow: 0 6px 48px rgba(0,0,0,.22);
  display:grid;
  grid-template-columns: var(--sw) 1fr;
  grid-template-rows: auto 1fr;
  overflow:hidden;          /* coupe tout débordement */
  font-size:7.8pt;
  line-height:1.42;
  color:var(--text);
}

/* ════════════════════════════════════════════
   EN-TÊTE (pleine largeur)
════════════════════════════════════════════ */
.cv-header {
  grid-column:1/-1;
  background:var(--navy);
  padding:15px 24px 13px;
  display:flex; align-items:center; gap:16px;
}
.avatar {
  width:56px; height:56px; border-radius:50%; flex-shrink:0;
  background:linear-gradient(135deg,var(--cyan),var(--teal));
  display:flex; align-items:center; justify-content:center;
  font-size:1.3rem; font-weight:700; color:#fff; letter-spacing:-1px;
}
.hd-text { flex:1; }
.hd-text h1 {
  font-size:1.18rem; font-weight:700; color:#fff;
  letter-spacing:-.02em; line-height:1.15; margin-bottom:2px;
}
.hd-sub { font-size:.75rem; color:var(--cyan2); font-weight:500; margin-bottom:6px; }
.badges { display:flex; flex-wrap:wrap; gap:4px; }
.badge {
  font-family:'JetBrains Mono',monospace; font-size:.57rem;
  padding:2px 7px; border-radius:3px;
  background:rgba(14,165,233,.13); border:1px solid rgba(14,165,233,.3); color:var(--cyan2);
  display:inline-flex; align-items:center;
}
.badge.g { background:rgba(13,148,136,.13); border-color:rgba(13,148,136,.3); color:#5eead4; }

.contacts { display:flex; flex-direction:column; gap:4px; align-items:flex-end; }
.ci { display:flex; align-items:center; gap:5px; font-size:.65rem; color:rgba(255,255,255,.72); }
.ci svg { width:10px; height:10px; fill:var(--cyan); flex-shrink:0; }

/* ════════════════════════════════════════════
   SIDEBAR
════════════════════════════════════════════ */
.sidebar {
  background:#f8fafc;
  border-right:1px solid var(--bdr);
  padding:13px 12px;
  display:flex; flex-direction:column; gap:12px;
  overflow:hidden;
}
.sb-h {
  font-family:'JetBrains Mono',monospace;
  font-size:.54rem; font-weight:600; color:var(--cyan);
  text-transform:uppercase; letter-spacing:.1em;
  border-bottom:1.5px solid var(--cyan);
  padding-bottom:3px; margin-bottom:6px; display:block;
}
/* skill bars */
.sk { margin-bottom:5px; }
.sk-lbl { display:flex; justify-content:space-between; margin-bottom:2px; }
.sk-n { font-size:.67rem; font-weight:500; }
.sk-p { font-size:.56rem; color:var(--muted); font-family:'JetBrains Mono',monospace; }
.sk-bar { height:4px; background:var(--bdr); border-radius:2px; overflow:hidden; }
.sk-fill { height:100%; border-radius:2px; background:linear-gradient(90deg,var(--cyan),var(--teal)); }
/* outils */
.tags { display:flex; flex-wrap:wrap; gap:3px; }
.tag {
  font-size:.57rem; font-family:'JetBrains Mono',monospace;
  background:#e0f2fe; color:#0369a1; border:1px solid #bae6fd;
  padding:1px 5px; border-radius:2px;
}
/* certifs */
.cert {
  background:linear-gradient(135deg,#0ea5e914,#0d948814);
  border:1px solid #bae6fd; border-radius:4px;
  padding:6px 8px; margin-bottom:4px;
}
.cert-n { font-size:.67rem; font-weight:600; color:var(--navy); margin-bottom:1px; }
.cert-o { font-size:.58rem; color:var(--muted); }
.cert-y { font-family:'JetBrains Mono',monospace; font-size:.55rem; color:var(--cyan); }
/* langues */
.lng { display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; }
.lng-n { font-size:.67rem; font-weight:500; }
.lng-l {
  font-size:.55rem; color:#fff; background:var(--navy);
  padding:1px 6px; border-radius:2px; font-family:'JetBrains Mono',monospace;
}
.lng-l.b { background:var(--cyan); color:var(--navy); }
/* soft */
.soft { font-size:.65rem; margin-bottom:4px; padding-left:10px; position:relative; }
.soft::before { content:'▸'; position:absolute; left:0; color:var(--cyan); font-size:.6rem; }

/* ════════════════════════════════════════════
   MAIN
════════════════════════════════════════════ */
.main {
  padding:13px 17px;
  display:flex; flex-direction:column; gap:10px;
  overflow:hidden;
}
.sec-h {
  font-size:.62rem; font-weight:700; color:var(--navy);
  text-transform:uppercase; letter-spacing:.1em;
  padding-bottom:4px; margin-bottom:7px;
  border-bottom:1.5px solid var(--navy);
  display:flex; align-items:center; gap:6px;
}
.sec-h::after {
  content:''; flex:1; height:1.5px;
  background:linear-gradient(90deg,var(--cyan),transparent);
}
/* profil */
.profil {
  font-size:.7rem; color:var(--muted); line-height:1.55;
  border-left:2.5px solid var(--cyan); padding-left:9px;
}
/* timeline */
.tl { display:flex; flex-direction:column; gap:7px; }
.tli { display:grid; grid-template-columns:8px 1fr; gap:0 8px; }
.dot-col { display:flex; flex-direction:column; align-items:center; padding-top:3px; }
.dot {
  width:7px; height:7px; border-radius:50%;
  background:var(--cyan); flex-shrink:0;
  border:1.5px solid #fff; box-shadow:0 0 0 1.5px var(--cyan);
}
.line { flex:1; width:1.5px; background:var(--bdr); margin-top:2px; }
.tl-head { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1px; }
.tl-t { font-size:.7rem; font-weight:600; line-height:1.3; }
.tl-d { font-family:'JetBrains Mono',monospace; font-size:.56rem; color:var(--cyan); white-space:nowrap; margin-left:5px; }
.tl-o { font-size:.62rem; color:var(--muted); margin-bottom:2px; }
.tl-ul { list-style:none; }
.tl-ul li {
  font-size:.64rem; color:var(--muted); line-height:1.4;
  padding-left:9px; position:relative; margin-bottom:1px;
}
.tl-ul li::before { content:'▸'; position:absolute; left:0; color:var(--cyan); font-size:.58rem; }
.tl-tags { display:flex; flex-wrap:wrap; gap:3px; margin-top:3px; }
.tl-tag {
  font-family:'JetBrains Mono',monospace; font-size:.56rem;
  color:#0369a1; background:#e0f2fe; border:1px solid #bae6fd;
  padding:1px 5px; border-radius:2px;
}

/* ════════════════════════════════════════════
   IMPRESSION  —  la seule règle qui compte
   On imprime exactement le rendu écran,
   mis à l'échelle pour tenir sur A4.
════════════════════════════════════════════ */
@media print {

  @page {
    size: A4 portrait;
    margin: 0;
  }

  /* Masquer tout sauf la page CV */
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    background: white !important;
    width: 210mm !important;
    height: 297mm !important;
  }

  .print-bar { display:none !important; }

  /*
    La page fait 794px × 1123px.
    A4 en mm = 210mm × 297mm.
    On demande au navigateur de la comprimer
    exactement pour remplir la feuille.
  */
  .page {
    margin: 0 !important;
    box-shadow: none !important;
    /* Convertit la page pixel en page mm exacte */
    width: 210mm !important;
    height: 297mm !important;
    /* Rétrécit les pixels pour coller au mm */
    zoom: calc(210mm / 794px);
    /* Fallback Firefox */
    -moz-transform: scale(calc(210 / 794 * (25.4 / 25.4)));
    -moz-transform-origin: top left;
    overflow: hidden !important;
    page-break-after: avoid;
    break-after: avoid;
  }

  * {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }
}

/* ── responsive mobile (écran) ── */
@media screen and (max-width: 860px) {
  .page { width:100%; height:auto; grid-template-columns:1fr; }
  .cv-header { flex-direction:column; }
  .contacts { align-items:flex-start; }
  .sidebar { border-right:none; border-bottom:1px solid var(--bdr); }
}
</style>
</head>
<body>

